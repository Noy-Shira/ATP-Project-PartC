<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="20"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.example.atpprojectpartc.View.WelcomeController"
      style="-fx-background-color: #1a1a2e;"
      prefWidth="600" prefHeight="600">

    <padding>
        <Insets top="30" bottom="30" left="30" right="30"/>
    </padding>

    <ImageView fitWidth="400" fitHeight="200" preserveRatio="true">
        <image>
            <Image url="@/Pnina.png"/>
        </image>
    </ImageView>

    <Label text="WELCOME TO THE MAZE"
           style="-fx-text-fill: white; -fx-font-size: 28px; -fx-font-weight: bold;"/>
    <Label text="ISRAEL VS IRAN"
           style="-fx-text-fill: white; -fx-font-size: 22px; -fx-font-weight: bold;"/>

    <!-- buttoms -->
    <Button fx:id="startButton" text="START"
            onAction="#onStart"
            prefWidth="200"
            style="-fx-background-color: #0f3460; -fx-text-fill: white;
                   -fx-font-size: 18px; -fx-padding: 10px 30px;
                   -fx-background-radius: 5px; -fx-cursor: hand;"/>

    <Button fx:id="loadButton" text="LOAD EXISTING MAZE"
            onAction="#onLoad"
            prefWidth="200"
            style="-fx-background-color: #0f3460; -fx-text-fill: white;
                   -fx-font-size: 18px; -fx-padding: 10px 30px;
                   -fx-background-radius: 5px; -fx-cursor: hand;"/>

</VBox>